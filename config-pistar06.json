{
    "output_dir": "outputs/pistar06_inference",
    "interactive": false,
    "use_rerun": false,
    "job_name": "pistar06_pickplace_inference",
    "resume": false,
    "seed": 42,
    "num_workers": 4,
    "batch_size": 2,
    "log_freq": 20,
    "save_checkpoint": false,
    "save_freq": 400,
    "offline_output_dir": "outputs/pistar06_inference",
    "offline_save_freq": 500,
    "buffer_cache_dir": "outputs/buffer_cache",
    "episode_logging_freq": 1,
    "episode_save_freq": 10,
    "video_logging_cameras": [
        "top",
        "side"
    ],
    "wandb": {
        "enable": false,
        "project": "pistar06_pickplace",
        "offline_project": "pistar06_pickplace_offline",
        "disable_artifact": true
    },
    "dataset": {
        "root": "outputs/so101_pickplace_success_120_v2_w_subtasks_v2",
        "repo_id": "jackvial/so101_pickplace_success_120_v2_w_subtasks_v2",
        "use_imagenet_stats": false,
        "max_episodes": null,
        "video_backend": "pyav"
    },
    "policy": {
        "type": "pistar06",
        "pretrained_path": "models/recap_baseline_120_v2",
        "tokenizer_max_length": 64,
        "max_state_dim": 6,
        "num_inference_steps": 5,
        "n_obs_steps": 1,
        "rtc_config": {
            "enabled": true,
            "execution_horizon": 10,
            "prefix_attention_schedule": "LINEAR",
            "max_guidance_weight": 10.0,
            "debug": false,
            "debug_maxlen": 100
        },
        "normalization_mapping": {
            "VISUAL": "IDENTITY",
            "STATE": "MIN_MAX",
            "ENV": "MIN_MAX",
            "ACTION": "QUANTILES"
        },
        "input_features": {
            "observation.images.top": {
                "type": "VISUAL",
                "shape": [3, 224, 224]
            },
            "observation.images.side": {
                "type": "VISUAL",
                "shape": [3, 224, 224]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [6]
            }
        },
        "output_features": {
            "action": {
                "type": "ACTION",
                "shape": [6]
            }
        },
        "device": "cuda",
        "use_amp": false,
        "dtype": "bfloat16",
        "gradient_checkpointing": false,
        "enable_advantage_conditioning": true,
        "advantage_threshold": 0.0,
        "cfg_beta": 1.0,
        "repo_id": "jackvial/so101_pickplace_success_120_v2_w_subtasks_v2"
    },
    "env": {
        "type": "gym_manipulator",
        "robot": {
            "type": "so101_follower",
            "port": "/dev/serial/by-id/usb-1a86_USB_Single_Serial_5876043763-if00",
            "id": "so101_follower_2026_04_16_v2",
            "cameras": {
                "top": {
                    "type": "opencv",
                    "index_or_path": "/dev/video0",
                    "height": 600,
                    "width": 800,
                    "fps": 30,
                    "fourcc": "MJPG"
                },
                "side": {
                    "type": "opencv",
                    "index_or_path": "/dev/video4",
                    "height": 600,
                    "width": 800,
                    "fps": 30,
                    "fourcc": "MJPG"
                }
            }
        },
        "teleop": {
            "type": "so101_leader",
            "port": "/dev/serial/by-id/usb-1a86_USB_Single_Serial_5A7A057748-if00",
            "id": "so101_leader_2026_04_16_v2"
        },
        "processor": {
            "control_mode": "leader",
            "observation": {
                "display_cameras": false,
                "add_joint_velocity_to_observation": false,
                "add_current_to_observation": false
            },
            "image_preprocessing": {
                "resize_size": [224, 224]
            },
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": 0.00
            },
            "reset": {
                "fixed_reset_joint_positions": [40.82, -99.03, 98.2, 80.4, -43.64, 5.39],
                "reset_time_s": 10,
                "control_time_s": 200.0,
                "terminate_on_success": true
            },
            "reward_classifier": {
                "pretrained_path": null,
                "success_threshold": 0.5,
                "success_reward": 1.0
            },
            "max_gripper_pos": 30
        },
        "name": "real_robot",
        "fps": 30,
        "task": "Pick up the orange cube and place it on the black X marker",
        "features": {
            "observation.images.top": {
                "type": "VISUAL",
                "shape": [3, 128, 128]
            },
            "observation.images.side": {
                "type": "VISUAL",
                "shape": [3, 128, 128]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [6]
            },
            "action": {
                "type": "ACTION",
                "shape": [6]
            }
        },
        "features_map": {
            "observation.images.top": "observation.images.top",
            "observation.images.side": "observation.images.side",
            "observation.state": "observation.state",
            "action": "action"
        }
    }
}
