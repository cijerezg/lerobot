{
    "output_dir": null,
    "job_name": "default",
    "resume": false,
    "seed": 42,
    "num_workers": 4,
    "batch_size": 30,
    "log_freq": 20,
    "save_checkpoint": true,
    "save_freq": 100,
    "offline_output_dir": "outputs/pi05_full_offline_training_v2",
    "offline_save_freq": 200,
    "online_buffer_save_episode_freq": 12,
    "wandb": {
        "enable": true,
        "project": "so101_real-v1",
        "offline_project": "so101_real_offline-v1",
        "disable_artifact": true
    },
    "dataset": {
        "root": "outputs/annotated_dataset-v3",
        "repo_id": "cijerezg/yellow-car-offline-training-v2",
        "use_imagenet_stats": false
    },
    "policy": {
        "type": "pi05_rl",
        "task": "Pick up the red truck and put it in the bowl",
        "pi05_checkpoint": "outputs/pi05_full_offline_training_v2/checkpoints/000600/pretrained_model",
        "tokenizer_max_length": 64,
        "max_state_dim": 6,
        "num_inference_steps": 5,
        "use_separate_critic": true,
        "knowledge_insulation": false,
        "loss_weight_flow": 1.0,
        "loss_weight_action_ce": 0.5,
        "loss_weight_subtask_ce": 0.25,
        "inference_advantage": 1.0,
        "advantage_scaling": 0.16,
        "n_obs_steps": 1,
        "reward_normalization_constant": 8.0,
        "terminal_failure_reward": -24.0,
        "rtc_config": {
            "enabled": true,
            "execution_horizon": 10,
            "prefix_attention_schedule": "LINEAR",
            "max_guidance_weight": 10.0,
            "debug": false,
            "debug_maxlen": 100
        },
        "normalization_mapping": {
            "VISUAL": "IDENTITY",
            "STATE": "MIN_MAX",
            "ENV": "MIN_MAX",
            "ACTION": "MIN_MAX"
        },
        "input_features": {
            "observation.images.wrist": {
                "type": "VISUAL",
                "shape": [
                    3,
                    224,
                    224
                ]
            },
            "observation.images.top": {
                "type": "VISUAL",
                "shape": [
                    3,
                    224,
                    224
                ]
            },
            "observation.images.side": {
                "type": "VISUAL",
                "shape": [
                    3,
                    224,
                    224
                ]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [
                    6
                ]
            }
        },
        "output_features": {
            "action": {
                "type": "ACTION",
                "shape": [
                    6
                ]
            }
        },
        "device": "cuda",
        "actor_device": "cuda:0",
        "learner_device": "cuda:0",
        "use_amp": false,
        "dataset_stats": null,
        "storage_device": "cpu",
        "dtype": "bfloat16",
        "gradient_checkpointing": true,
        "online_steps": 20000,
        "online_buffer_capacity": 30000,
        "offline_buffer_capacity": 80000,
        "online_step_before_learning": 10,
        "policy_update_freq": 1,
        "discount": 0.97,
        "async_prefetch": false,
        "num_critics": 1,
        "critic_lr": 0.00005,
        "actor_lr": 0.00005,
        "critic_target_update_weight": 0.005,
        "utd_ratio": 2,
        "grad_clip_norm": 2.0,
        "gradient_accumulation_steps": 3,
        "critic_network_kwargs": {
            "hidden_dims": [
                256,
                256
            ],
            "activate_final": true
        },
        "actor_learner_config": {
            "learner_host": "127.0.0.1",
            "learner_port": 50051,
            "policy_parameters_push_frequency": 120
        },
        "concurrency": {
            "actor": "threads",
            "learner": "threads"
        },
        "repo_id": "cijerezg/multi-task-toys-merged-v2"
    },
    "env": {
        "type": "gym_manipulator",
        "robot": {
            "type": "so101_follower",
            "port": "/dev/ttyACM0",
            "id": "follower_arm_v2",
            "cameras": {
                "wrist": {
                    "type": "opencv",
                    "index_or_path": 2,
                    "height": 480,
                    "width": 640,
                    "fps": 30
                },
                "top": {
                    "type": "opencv",
                    "index_or_path": 4,
                    "height": 480,
                    "width": 640,
                    "fps": 30
                },
                "side": {
                    "type": "opencv",
                    "index_or_path": 0,
                    "height": 480,
                    "width": 640,
                    "fps": 30
                }
            }
        },
        "teleop": {
            "type": "so101_leader",
            "port": "/dev/ttyACM1",
            "id": "leader_arm_v2"
        },
        "processor": {
            "control_mode": "leader",
            "observation": {
                "display_cameras": false,
                "add_joint_velocity_to_observation": false,
                "add_current_to_observation": false
            },
            "image_preprocessing": {
                "resize_size": [
                    224,
                    224
                ]
            },
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": 0.00
            },
            "reset": {
                "fixed_reset_joint_positions": [
                    0.37,
                    -72.3,
                    75.4,
                    83.5,
                    12.9,
                    29.9
                ],
                "reset_time_s": 10,
                "control_time_s": 200.0,
                "terminate_on_success": true
            },
            "reward_classifier": {
                "pretrained_path": null,
                "success_threshold": 0.5,
                "success_reward": 1.0
            },
            "max_gripper_pos": 30
        },
        "name": "real_robot",
        "fps": 30,
        "task": "Pick up the yellow car and put it in the bowl",
        "features": {
            "observation.images.wrist": {
                "type": "VISUAL",
                "shape": [
                    3,
                    128,
                    128
                ]
            },
            "observation.images.top": {
                "type": "VISUAL",
                "shape": [
                    3,
                    128,
                    128
                ]
            },
            "observation.images.side": {
                "type": "VISUAL",
                "shape": [
                    3,
                    128,
                    128
                ]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [
                    6
                ]
            },
            "action": {
                "type": "ACTION",
                "shape": [
                    6
                ]
            }
        },
        "features_map": {
            "observation.images.wrist": "observation.images.wrist",
            "observation.images.top": "observation.images.top",
            "observation.images.side": "observation.images.side",
            "observation.state": "observation.state",
            "action": "action"
        }
    }
}